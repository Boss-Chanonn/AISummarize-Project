MONGO_URL=
DATABASE_NAME=learnova
SECRET_KEY=
ALLOWED_ORIGINS=http://localhost:8000
APP_URL=http://localhost:8000
OLLAMA_ENABLED=true
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3:latest
OLLAMA_TIMEOUT_SECONDS=300
OLLAMA_NUM_PREDICT=1024
SUMMARY_NUM_PREDICT=1024
QUIZ_NUM_PREDICT=1024
AI_SUMMARY_MAX_CHARS=1500
AI_SUMMARY_CHUNK_SIZE=2000
SUMMARY_OLLAMA_URL=http://host.docker.internal:11434
SUMMARY_MODEL=llama3:latest
QUIZ_OLLAMA_URL=http://host.docker.internal:11434
QUIZ_MODEL=llama3:latest

# EC2 Bridge (set this on Lambda/cloud instead of direct Tailscale URLs)
# BRIDGE_URL=http://54.206.73.1:8000

EMAIL_FROM=
SMTP_USER=
SMTP_PASS=
 
# Calendar Integration (Google + Outlook + Apple)
# Google Calendar — set these to enable real OAuth (leave empty for mock/ics mode)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
 
# Outlook Calendar — set these to enable real OAuth (leave empty for mock/ics mode)
OUTLOOK_CLIENT_ID=
OUTLOOK_CLIENT_SECRET=
OUTLOOK_REDIRECT_URI=
